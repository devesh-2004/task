# Supabase POOLED connection string (Transaction pooler, port 6543).
# Use the pooler for serverless (Vercel) so you don't exhaust Postgres connections.
# Find it in: Supabase Dashboard -> Project Settings -> Database -> Connection string -> "Transaction pooler".
#
# Note the port is 6543 (pooled), NOT 5432 (direct). The seed script also works
# against this, but for a one-off bulk seed the direct (5432) string is fine too.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"